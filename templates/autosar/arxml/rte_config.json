{
  "comment": "yuleASR RTE Configuration — generated by yuleOSH init-autosar",
  "version": "1.0.0",
  "autosar_version": "R20-11",

  "components": [
    {
      "short_name": "SeatControl",
      "type": "ApplicationSwComponentType",
      "runnables": [
        {
          "short_name": "UpdatePosition",
          "symbol": "SeatControl_UpdatePosition",
          "period_seconds": 0.01,
          "minimum_start_interval": 0.01,
          "can_be_invoked_concurrently": false,
          "data_access": {
            "reads": ["VehicleSpeedIn/Speed"],
            "writes": ["SeatPositionOut/Position", "SeatPositionOut/ReclineAngle"]
          }
        },
        {
          "short_name": "AdjustSeatPosition",
          "symbol": "SeatControl_AdjustPosition",
          "period_seconds": 0.1,
          "can_be_invoked_concurrently": false,
          "server_calls": [
            {
              "port": "SeatControlService",
              "operation": "AdjustPosition"
            }
          ]
        }
      ],
      "ports": [
        {
          "short_name": "SeatPositionOut",
          "direction": "out",
          "interface": "SeatPosition_I",
          "kind": "SenderReceiver",
          "data_elements": ["Position", "ReclineAngle"]
        },
        {
          "short_name": "VehicleSpeedIn",
          "direction": "in",
          "interface": "VehicleSpeed_I",
          "kind": "SenderReceiver",
          "data_elements": ["Speed"]
        },
        {
          "short_name": "SeatControlService",
          "direction": "in",
          "interface": "SeatControl_I",
          "kind": "ClientServer",
          "operations": ["AdjustPosition", "StoreMemoryPosition"]
        }
      ]
    }
  ],

  "scheduling": {
    "mode": "periodic",
    "default_task_priority": 10,
    "task_stack_size": 2048,
    "rte_timer_resolution_us": 100,
    "runnable_schedule": [
      {"runnable": "UpdatePosition", "task": "Task_10ms", "priority": 10},
      {"runnable": "AdjustSeatPosition", "task": "Task_100ms", "priority": 8}
    ]
  },

  "generation": {
    "output_dir": "src/rte",
    "generate_type_header": true,
    "generate_rte_h": true,
    "generate_rte_c": true,
    "generate_swc_stubs": true,
    "generate_mock_impl": true
  }
}
