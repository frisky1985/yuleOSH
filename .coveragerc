[run]
source = src/yuleosh
branch = true
omit =
    */templates/*
    */hardware/*
    */cross/*
    */sil/*
    */plugins/sandbox.py
    */store_pg.py
    */llm/client.py
    */_entry.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    raise ImportError
    except ImportError
    def _get_secret
    def main
    def _check_llm_key
fail_under = 60

[paths]
source =
    src/yuleosh
    */site-packages/yuleosh
