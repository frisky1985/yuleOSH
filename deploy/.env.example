# =============================================================================
# yuleOSH — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp deploy/.env.example .env
# =============================================================================

# ── Domain & SSL ──────────────────────────────
DOMAIN=yuleosh.io

# ── Database ──────────────────────────────────
PG_PASSWORD=change-me-to-strong-random-password

# ── Backend ───────────────────────────────────
YULEOSH_JWT_SECRET=change-me-to-random-string-at-least-32-chars
YULEOSH_API_KEY=
YULEOSH_BASE_URL=https://yuleosh.io
YULEOSH_LOG_LEVEL=info
YULEOSH_ENV=production

# ── Frontend ──────────────────────────────────
FRONTEND_TAG=latest
NEXT_PUBLIC_API_BASE_URL=https://yuleosh.io

# ── Docker image tags (optional overrides) ────
YULEOSH_TAG=latest

# ── Stripe (optional — billing) ──────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications (optional) ──────────────────
YULEOSH_NOTIFY_FEISHU_URL=
YULEOSH_NOTIFY_EMAIL_SMTP=
YULEOSH_NOTIFY_EMAIL_USER=
YULEOSH_NOTIFY_EMAIL_PASS=

# ── Monitoring (optional) ─────────────────────
GRAFANA_PASSWORD=admin
