{
  "name": "yuleosh-desktop",
  "version": "0.1.0",
  "description": "yuleOSH Desktop \u2014 \u5d4c\u5165\u5f0fAI\u5f00\u53d1\u5168\u6d41\u7a0b\u5e73\u53f0",
  "author": "frisky1985",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=true electron .",
