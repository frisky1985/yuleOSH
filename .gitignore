# yuleOSH gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Coverage
.coverage
.coverage.*
coverage.json
htmlcov/
*.py,cover

# Pytest
.pytest_cache/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Environment
.env
.venv/
venv/

# Secrets / certificates
*.key
*.pem

# Unity coverage artifacts
tests/unity/coverage-*
tests/unity/*.info

# Runtime data (persistent DB, session state)
.yuleosh/
!.yuleosh/ci-config.yaml

# Loop engineering auto-generated artifacts
fmea_entries/
improvement_tickets/
kpi_trends/
kg_confidence_trend/
reports/safety-impact-*.md
rereview_tickets/

# Dogfooding — local-only self-referential projects
self/

# OSH build artifacts (keep .gitkeep markers)
.osh/ci/
.osh/evidence/
.osh/sessions/
.osh/reviews/
.osh/store.db
desktop/node_modules/
node_modules/
*.pyc
